{
  "name": "nexofit-backend",
  "version": "1.0.0",
  "description": "Backend API para NexoFit - Sistema de gestión de clases fitness",
  "main": "src/app.js",
  "type": "commonjs",
  "scripts": {
    "start": "node --env-file=.env src/app.js",
    "dev": "nodemon --env-file=.env src/app.js",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testMatch": [
      "**/*.test.js"
    ]
  },
  "keywords": [
    "fitness",
    "gym",
    "booking",
    "api"
  ],
  "author": "NexoFit Team",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-validator": "^7.3.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "mysql2": "^3.16.3",
    "sqlite3": "^5.1.7",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}

# Configuración de Base de Datos
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASS=your_password
DATABASE_NAME=nexofit

# Configuración de JWT
JWT_SECRET=nexofit_super_secret_key_change_this_in_production
JWT_REFRESH_SECRET=nexofit_refresh_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Configuración Docker (DEV)
MARIADB_ROOT_PASSWORD=your_password
MARIADB_DATABASE=nexofit

# Configuración del servidor
NODE_ENV=development
PORT=8080
